# Server port
PORT=3001

# HTTP Basic auth credentials required for all /api routes
API_USER=unity
API_PASS=changeme
API_REALM=Addressables

# Where uploaded bundles/catalogs are stored on disk
STORAGE_DIR=./storage

# Max upload size per file in bytes (default 512 MB)
MAX_FILE_SIZE=536870912

# When true, downloading from /content also requires basic auth
# (Unity supplies it via Addressables.WebRequestOverride — see examples/unity)
PROTECT_DOWNLOADS=false
